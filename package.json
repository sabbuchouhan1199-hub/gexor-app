{
  "name": "gexor-app",
  "version": "2.2.0",
  "private": true,
  "description": "Gexor AI Runtime Platform",
  "license": "UNLICENSED",
  "engines": {
    "node": "24.18.x",
    "npm": "11.16.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "10.0.3",
    "typescript": "7.0.2"
  },
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names API,WORKER,WEB \"npm run dev --workspace apps/api\" \"npm run worker --workspace apps/api\" \"npm run dev --workspace apps/web\"",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:worker": "npm run worker --workspace apps/api",
    "backup": "npm run backup --workspace apps/api",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "verify": "npm run typecheck && npm run test && npm run build",
    "test": "npm run test --workspaces --if-present"
  }
}
