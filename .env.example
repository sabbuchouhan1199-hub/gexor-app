# Gexor API local development configuration
HOST=127.0.0.1
PORT=3001
NODE_ENV=development
GEXOR_ALLOWED_ORIGIN=http://127.0.0.1:5173
GEXOR_DATABASE_PATH=.data/gexor.sqlite

# Vite development proxy target
VITE_API_TARGET=http://127.0.0.1:3001

# Text provider selection
TEXT_PROVIDER=ollama

# Local Ollama provider
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:0.6b
OLLAMA_TIMEOUT_MS=120000

# Google Gemini provider
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT_MS=120000

# Secure local attachment storage (never place this under a public web directory)
GEXOR_UPLOAD_PATH=.data/uploads
GEXOR_MAX_UPLOAD_BYTES=5242880
GEXOR_MAX_WORKSPACE_UPLOAD_BYTES=26214400
GEXOR_MAX_CONVERSATION_FILES=20

# SQLite online backups
GEXOR_BACKUP_PATH=.data/backups
GEXOR_BACKUP_RETENTION=7
