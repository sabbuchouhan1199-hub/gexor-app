{
  "name": "@gexor/api",
  "version": "0.1.0",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "fastify": "5.10.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "tsx": "4.23.1"
  },
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=../../.env --import tsx src/server.ts",
    "worker": "node --env-file-if-exists=../../.env --import tsx src/worker.ts",
    "backup": "node --env-file-if-exists=../../.env --import tsx src/operations/backup.ts",
    "start": "node --env-file-if-exists=../../.env --import tsx src/server.ts",
    "typecheck": "tsc --project tsconfig.json",
    "test": "tsx --test src/*.test.ts"
  }
}
