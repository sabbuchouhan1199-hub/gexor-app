{
  "name": "gexor-app",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "gexor-app",
      "version": "0.1.0",
      "license": "UNLICENSED",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": "24.18.x",
        "npm": "11.16.x"
      }
    },
    "apps/api": {
      "name": "@gexor/api",
      "version": "0.1.0",
      "license": "UNLICENSED"
    },
    "apps/web": {
      "name": "@gexor/web",
      "version": "0.1.0",
      "license": "UNLICENSED"
    },
    "node_modules/@gexor/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@gexor/web": {
      "resolved": "apps/web",
      "link": true
    }
  }
}
